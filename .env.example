# psephos credentials. Copy to .env and fill in. Do NOT commit the real .env.

# Congress.gov API key (free): https://api.congress.gov
CONGRESS_API_KEY=

# CourtListener API token (free account): https://www.courtlistener.com/help/api/rest/
COURTLISTENER_TOKEN=

# Federal Register API needs no key.

# Turso (libSQL) persistence — the psephos DB in the csu-j3 group (same env names
# as cbt/ccbt). When TURSO_DATABASE_URL is set, collectors and export use Turso;
# unset it to fall back to a local data/psephos.db. The URL is bare (no angle
# brackets). Get both from the Turso dashboard or `turso db tokens create psephos`.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# State legislation (channel 5):
# LegiScan API key (free tier, 30k queries/month): https://legiscan.com/legiscan
LEGISCAN_API_KEY=
